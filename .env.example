# API 認証トークン（/api/tickets の Bearer 認証）
API_TOKEN=your-api-token

# ===== Square 連携 =====
# Square API アクセストークン（Developer Dashboard で取得）
SQUARE_ACCESS_TOKEN=your-square-access-token

# Webhook 署名キー（Square Developer Dashboard の Webhooks で発行）
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key

# Square に登録した通知先URL（署名検証で使用、完全一致が必要）
# 例: https://example.com/api/square/webhook
SQUARE_WEBHOOK_URL=https://recipient-number-display-app.onrender.com/api/square/webhook

# 環境: sandbox | production（既定: production）
SQUARE_ENV=sandbox
